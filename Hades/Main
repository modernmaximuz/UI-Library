    title   = title   or "Hades"
    logoId  = logoId  or ""

    -- ScreenGui
    local ScreenGui = newInst("ScreenGui", {
        Name            = "HadesGui_" .. title,
        Parent          = game.CoreGui,
        ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn    = false,
    })

    -- Shadow / drag root
    local Shadow = newInst("Frame", {
        Name              = "Shadow",
        Parent            = ScreenGui,
        BackgroundColor3  = Color3.fromRGB(0,0,0),
        BackgroundTransparency = 0.5,
        BorderSizePixel   = 0,
        Position          = UDim2.new(0.5, -277, 0.5, -226),
        Size              = UDim2.new(0, 554, 0, 452),
    })
    corner(Shadow, 10)

    -- Main window frame
    local Main = newInst("Frame", {
        Name             = "Main",
        Parent           = Shadow,
        BackgroundColor3 = C.bg,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 1, 0),
    })
    corner(Main, 10)

task.spawn(function()
    if autoLoad then
        local data = HadesLib:LoadConfig()
        if data then
            print("Loaded config:", currentSave)
        end
    end
end)
