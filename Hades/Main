    })
    corner(HideKey, 4)

    newInst("TextLabel", {
        Parent               = Sidebar,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 90, 1, -52),
        Size                 = UDim2.new(0, 60, 0, 20),
        Font                 = Enum.Font.Gotham,
        Text                 = "Hide GUI",
        TextColor3           = C.muted,
        TextSize             = 10,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    newInst("TextLabel", {
        Parent               = Sidebar,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 10, 1, -30),
        Size                 = UDim2.new(1, -10, 0, 18),
        Font                 = Enum.Font.Code,
        Text                 = "Player: " .. LocalPlayer.Name,
        TextColor3           = C.muted,
        TextSize             = 9,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

